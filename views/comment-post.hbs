<div class="post">

    <article class="card">
        <div class="card-header flex-row justify-space-between">
            <h2>{{post.title}}</h2>
            <div>
                Posted by {{post.user.username}} on {{format_date post.createdAt}}
            </div>
        </div>
        <div class="card-body">
            {{post.contents}}
        </div>

    </article>

    {{#if post.Comments}}
    <section class="card">
        <div class="card-header">
            <h3>Comments</h3>
        </div>

        <div class="card-body">
            {{#each post.Comments}}
            <div>
                <p>
                    {{body}}
                </p>
                <p>
                    &mdash; {{User.username}}, {{createdAt}}
                </p>
            </div>
            {{/each}}
        </div>
    </section>
    {{/if}}

    <form id="new-comment" class="card">
        <div class="card-header">
            <h3>Add a Comment</h3>
        </div>

        <div class="card-body">
            <input type="hidden" name="post-id" value="{{post.id}}" />

            <label class="form-label">Comment</label>
            <textarea name="comment-body" class="form-control" id="exampleFormControlTextarea1" rows="3">
              </textarea name="comment-body">
            

            <button type="submit" class="btn btn-success">Submit</button>
        </div>
    </form>
</div>

<script src="/javascript/comment.js"></script>